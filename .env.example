# Configuración de la Base de Datos
# Formato: postgresql://usuario:password@host:puerto/nombre_bd
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meme_fabrica

# Mostrar logs de SQL (útil para desarrollo)
ECHO_SQL=True

# Seguridad y JWT
# Genera una SECRET_KEY segura usando: openssl rand -hex 32
SECRET_KEY=tu_clave_secreta_super_segura_aqui
ALGORITHM=HS256

# Tiempos de expiración (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30